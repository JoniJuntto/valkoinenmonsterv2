{
  "name": "valkoinenmonsterv2",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/bun": "^1.3.14",
      "elysia": "^1.4.29",
      "@trpc/server": "^11.18.0",
      "better-auth": "1.6.23",
      "evlog": "^2.19.2",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.3.2",
      "@trpc/client": "^11.18.0",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter='!desktop' && turbo run build -F desktop",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:desktop": "turbo run dev:hmr -F desktop",
    "build:desktop": "turbo run build:stable -F desktop",
    "build:desktop:canary": "turbo run build:canary -F desktop",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @valkoinenmonsterv2/db",
    "db:studio": "turbo run db:studio -F @valkoinenmonsterv2/db",
    "db:generate": "turbo run db:generate -F @valkoinenmonsterv2/db",
    "db:migrate": "turbo run db:migrate -F @valkoinenmonsterv2/db",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@valkoinenmonsterv2/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/bun": "catalog:",
    "@valkoinenmonsterv2/config": "workspace:*",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "ultracite": "7.9.3"
  },
  "packageManager": "bun@1.3.14"
}
