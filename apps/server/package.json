{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/trpc": "^1.1.0",
    "@hono/trpc-server": "^0.4.2",
    "@sinclair/typebox": "^0.34.49",
    "@trpc/server": "catalog:",
    "@valkoinenmonsterv2/api": "workspace:*",
    "@valkoinenmonsterv2/auth": "workspace:*",
    "@valkoinenmonsterv2/db": "workspace:*",
    "@valkoinenmonsterv2/env": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "catalog:",
    "evlog": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@valkoinenmonsterv2/config": "workspace:*",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "unrun": "^0.3.1"
  }
}
